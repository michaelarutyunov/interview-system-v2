# API Keys (required for providers you use)
ANTHROPIC_API_KEY=your-api-key-here
KIMI_API_KEY=your-api-key-here
XAI_API_KEY=your-api-key-here
DEEPSEEK_API_KEY=your-api-key-here
OPENAI_API_KEY=your-api-key-here

# API costs (per mln tokens, https://www.llm-prices.com/)

## Anthropic: https://platform.claude.com/docs/en/about-claude/pricing
ANTHROPIC_SONNET_INPUT="3.00"
ANTHROPIC_SONNET_OUTPUT="15.00"

## Anthropic: https://platform.claude.com/docs/en/about-claude/pricing
ANTHROPIC_HAIKU_INPUT="1.00"
ANTHROPIC_HAIKU_OUTPUT="5.00"

## Kimi: https://platform.moonshot.ai/docs/pricing/chat#generation-model-kimi-k2
KIMI_K2_INPUT="0.60"
KIMI_K2_OUTPUT="2.50"

## xAI Grok: https://docs.x.ai/docs/models#models-and-pricing
GROK_41_FAST_INPUT="0.20"
GROK_41_FAST_OUTPUT="0.50"

## DeepSeek Chat
DEEPSEEK_CHAT_INPUT="0.27"
DEEPSEEK_CHAT_OUTPUT="1.10"

## OpenAI GPT-5.1
OPENAI_GPT51_INPUT="1.25"
OPENAI_GPT51_OUTPUT="10.0"

# Database
DATABASE_PATH=data/interview.db

# Server
DEBUG=true
HOST=127.0.0.1
PORT=8000
